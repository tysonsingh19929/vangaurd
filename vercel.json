{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/server.js"
    },
    {
      "source": "/index.css",
      "destination": "/public/index.css"
    },
    {
      "source": "/app.js",
      "destination": "/public/app.js"
    },
    {
      "source": "/:path*",
      "destination": "/public/index.html"
    }
  ]
}
